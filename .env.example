# Copy to `.env.local` and fill in values. Never commit real secrets.

# Supabase (app + server)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Worker / queue
REDIS_URL=

# Optional tests
# TEST_BASE_URL=http://localhost:3000

# Storage: bucket name for reference uploads is fixed in docs (not an env var):
#   Bucket: project-media — create in Supabase dashboard.
#   Path / asset_key rules: docs/storage-conventions.md
